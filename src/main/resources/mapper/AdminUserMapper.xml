<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- 관리자 회원 관리 매퍼 -->
<!-- - 회원 승인/거부 -->
<!-- - 입주민 검색 (동/호수 기준) -->
<mapper namespace="com.apt.user.mapper.AdminUserMapper">

    <!-- ── 유저 단건 조회 ───────────────────────────────────────── -->
    <!-- 승인/거부 전 존재 확인용 -->
    <!-- user_id로 유저 조회 → AdminUserRes 반환 -->
    <select id="findById" parameterType="long" resultType="com.apt.user.dto.response.AdminUserRes">
        SELECT user_id,
               household_id,
               name,
               email,
               phone,
               role,
               status
        FROM user
        WHERE user_id = #{userId}
          AND is_deleted = 0
    </select>

    <!-- ── 유저 상태 변경 ───────────────────────────────────────── -->
    <!-- status: APPROVED(승인) / REJECTED(거부) -->
    <update id="updateStatus">
        UPDATE user
        SET status = #{status}
        WHERE user_id = #{userId}
    </update>

    <!-- ── 세대 입주 이력 등록 ──────────────────────────────────── -->
    <!-- 회원 승인 시 household_history에 '입주' 이력 자동 등록 -->
    <!-- changed_at: NOW() 기본값 사용 -->
    <insert id="insertHistory">
        INSERT INTO household_history (household_id, user_id, status, changed_at)
        VALUES (#{householdId}, #{userId}, '입주', NOW())
    </insert>

    <!-- ── 입주민 검색 ───────────────────────────────────────────── -->
    <!-- dong, ho 각각 선택 입력 (둘 다 null이면 서비스단에서 예외 처리) -->
    <!-- dong만 입력: 해당 동 전체 입주민 조회 -->
    <!-- ho만 입력: 전체 동에서 해당 호수 입주민 조회 -->
    <!-- dong + ho 입력: 해당 동/호수 입주민 조회 -->
    <!-- is_deleted=0, role=RESIDENT, status=APPROVED 조건 고정 -->
    <select id="searchByHo" resultType="com.apt.user.dto.response.UserSearchRes">
        SELECT
        u.user_id,
        u.name,
        u.phone,
        h.dong,
        h.ho,
        u.status
        FROM user u
        JOIN household h ON u.household_id = h.household_id
        WHERE u.is_deleted = 0
        AND u.role = 'RESIDENT'
        AND u.status = 'APPROVED'
        <!-- dong이 있을 때만 동 조건 추가 -->
        <if test="dong != null and dong != ''">
            AND h.dong = #{dong}
        </if>
        <!-- ho가 있을 때만 호수 조건 추가 -->
        <if test="ho != null and ho != ''">
            AND h.ho = #{ho}
        </if>
    </select>

    <!-- ── 승인 대기 목록 조회 ──────────────────────────────────── -->
    <!-- status = PENDING 인 유저 리스트 반환 -->
    <!-- 관리자가 승인/거절 처리할 대상 목록 -->
    <!-- 가입일 최신순 정렬 -->
    <select id="findByStatus" resultType="com.apt.user.dto.response.UserSearchRes">
        SELECT u.user_id,
               u.name,
               u.phone,
               h.dong,
               h.ho,
               u.status
        FROM user u
                 LEFT JOIN household h ON u.household_id = h.household_id
        WHERE u.status = #{status}
          AND u.is_deleted = 0
        ORDER BY u.created_at DESC
    </select>

</mapper>