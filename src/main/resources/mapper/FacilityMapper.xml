<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.apt.facility.mapper.FacilityMapper">

    <!-- 공통 컬럼 재사용 -->
    <sql id="facilityColumns">
        facility_id   AS facilityId,
        type_id       AS typeId,
        name,
        description,
        max_capacity  AS maxCapacity,
        open_time     AS openTime,
        close_time    AS closeTime,
        slot_duration AS slotDuration,
        is_active     AS isActive,
        created_at    AS createdAt
    </sql>

    <!-- 시설 단건 조회 -->
    <!-- 사용처: 예약 생성 시 시설 존재 확인 / 예약 가능 시간대 조회 시 운영시간·정원 조회 -->
    <select id="findById"
            parameterType="long"
            resultType="com.apt.facility.model.Facility">
        SELECT
        <include refid="facilityColumns"/>
        FROM facility
        WHERE facility_id = #{facilityId}
    </select>

    <!-- 운영 중인 실제 시설 전체 조회 -->
    <select id="findAllActiveFacilities"
            resultType="com.apt.facility.model.Facility">
        SELECT
        <include refid="facilityColumns"/>
        FROM facility
        WHERE is_active = 1
    </select>

    <!-- 시설 타입 전체 조회 -->
    <select id="findAllTypes"
            resultType="com.apt.facility.model.FacilityType">
        SELECT
            type_id    AS typeId,
            name,
            description,
            created_at AS createdAt
        FROM facility_type
    </select>

    <!-- 예약 현황 페이지 시설 조회 -->
    <select id="getFacilityList"
            resultType="com.apt.facility.dto.response.FacilityListRes">
        SELECT
            f.facility_id AS facilityId,
            f.name AS facilityName,
            ft.type_id AS typeId,
            ft.name AS typeName,
            f.max_capacity AS maxCapacity
        FROM facility f
                 JOIN facility_type ft
                      ON f.type_id = ft.type_id
    </select>


</mapper>