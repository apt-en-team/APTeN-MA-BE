<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.apt.board.mapper.BoardImageMapper">

    <!-- 이미지 목록 저장 -->
    <insert id="insertImages">
        INSERT INTO board_image (board_id, image_url)
        VALUES
        <foreach collection="images" item="url" separator=",">
            (#{boardId}, #{url})
        </foreach>
    </insert>

    <!-- 이미지 목록 조회 -->
    <select id="findByBoardId" resultType="com.apt.board.model.BoardImage">
        SELECT board_id, image_url
        FROM board_image
        WHERE board_id = #{boardId}
    </select>

    <!-- 이미지 전체 삭제 -->
    <delete id="deleteByBoardId">
        DELETE FROM board_image WHERE board_id = #{boardId}
    </delete>

</mapper>